---
/**
 * Accessible animation embed following the site convention for the Tier-1
 * WebM clips generated by scripts/generate_animations.py: four source
 * variants per clip (EN/ES x light/dark) served from raw.githubusercontent,
 * lazy (preload="none") with a poster and reserved space (width/height), no
 * autoplay ever. On top of the raw <video> convention this adds a required
 * accessible name and description (aria-label + aria-describedby), a visible
 * localized download link per variant, an in-element textual fallback, and an
 * optional visible caption.
 *
 * The page language picks the EN/ES sources; the light/dark pair is emitted
 * together and the active theme is resolved by the light-only/dark-only
 * classes (src/styles/theme-images.css), matching the figure convention.
 */
interface Props {
	/** Clip basename in .github/images, e.g. "anim_specific_loudness". */
	name: string;
	/** Short accessible name for the animation. */
	title: string;
	/** Textual alternative: what the animation shows, for screen readers. */
	description: string;
	/** Intrinsic pixel size of the WebM, to reserve layout space. */
	width: number;
	/** Intrinsic pixel size of the WebM, to reserve layout space. */
	height: number;
	/**
	 * Authored display width tier (see theme-images.css). 88% is the standard
	 * animation tier: full column on phones, 92% on desktop.
	 */
	displayWidth?: string;
	/** Optional visible caption below the animation. */
	caption?: string;
	/**
	 * Override for the generated element ids (aria-describedby targets).
	 * Only needed when the same clip is embedded more than once on a page,
	 * to keep the ids unique.
	 */
	id?: string;
}

const IMAGES = 'https://raw.githubusercontent.com/jmrplens/phonometry/main/.github/images';

const { name, title, description, width, height, displayWidth = '88%', caption, id } = Astro.props;
const { lang } = Astro.locals.starlightRoute;
const t = Astro.locals.t;

const langSuffix = lang.startsWith('es') ? '_es' : '';
const idBase = (id ?? name).replaceAll('_', '-');
const variants = (['light', 'dark'] as const).map((theme) => {
	const base = `${name}${langSuffix}${theme === 'dark' ? '_dark' : ''}`;
	return {
		theme,
		className: `${theme}-only`,
		src: `${IMAGES}/${base}.webm`,
		poster: `${IMAGES}/${base}_poster.jpg`,
		descriptionId: `${idBase}-${theme}-desc`,
	};
});
---

{
	variants.map((variant) => (
		<figure class={`video-figure ${variant.className}`}>
			<video
				src={variant.src}
				poster={variant.poster}
				width={width}
				height={height}
				preload="none"
				loop
				muted
				controls
				playsinline
				aria-label={title}
				aria-describedby={variant.descriptionId}
				style={`width:${displayWidth}`}
			>
				<p>
					{t('phonometry.video.fallback')}{' '}
					<a href={variant.src} rel="noopener">
						{title} (WebM)
					</a>
				</p>
			</video>
			<p class="sr-only" id={variant.descriptionId}>
				{description}
			</p>
			<p class="video-download">
				<a href={variant.src} download rel="noopener">
					{t('phonometry.video.download')}
				</a>
			</p>
			{/* Kept last: <figcaption> must be the first or last child of <figure>. */}
			{caption && <figcaption>{caption}</figcaption>}
		</figure>
	))
}

<style>
	/* The figure joins the markdown block flow; the inner <video> keeps the
	   site-wide treatment from theme-images.css (centred, rounded, responsive
	   width tiers keyed on the inline style). */
	.video-figure {
		margin-inline: 0;
	}
	.video-download {
		text-align: center;
		font-size: var(--sl-text-sm);
		margin-top: 0.5rem !important;
	}
	figcaption {
		text-align: center;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-2);
		margin-top: 0.5rem;
	}
	/* Starlight has no global visually-hidden utility outside its own
	   components, so the description carries its own. */
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		margin: -1px;
		padding: 0;
		overflow: hidden;
		clip-path: inset(50%);
		white-space: nowrap;
		border: 0;
	}
</style>
