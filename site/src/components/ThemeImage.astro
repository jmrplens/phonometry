---
/**
 * Theme-aware figure pair following the site convention for the images
 * generated by scripts/generate_graphs.py and scripts/generate_diagrams.py:
 * every figure ships a light and a dark variant (`_dark` suffix before the
 * extension; Spanish pages point at the `_es` variant and derive
 * `_es_dark`). Authoring a figure used to mean two hand-written <img> tags
 * with the alt text duplicated; this component takes the light URL and one
 * alt and emits the same light-only/dark-only pair, so the rendered HTML —
 * and the CSS switch plus the responsive width tiers in
 * src/styles/theme-images.css, keyed on the inline `width:NN%` style — is
 * unchanged.
 */
interface Props {
	/** URL of the light variant; the dark URL derives from it. */
	src: string;
	/** Alternative text, required and shared by both theme variants. */
	alt: string;
	/**
	 * Authored display width tier, e.g. "80%" (see theme-images.css:
	 * 60/70 small schematics, 80 detailed plots, 88/92 wide diagrams).
	 * Emitted as the inline style the responsive tiers key on.
	 */
	width?: string;
	/** Native lazy-loading. Pass "eager" for a page's above-the-fold figure. */
	loading?: 'lazy' | 'eager';
}

const { src, alt, width, loading = 'lazy' } = Astro.props;

if (!alt?.trim()) {
	throw new Error(`ThemeImage requires a non-empty alt (src: ${src})`);
}
const darkSrc = src.replace(/(\.[A-Za-z0-9]+)$/, '_dark$1');
if (darkSrc === src) {
	throw new Error(`ThemeImage could not derive the dark variant of "${src}"`);
}
const style = width ? `width:${width}` : undefined;
---

{/* Same-line pair, matching the hand-authored markup this replaces. */}
<img class="light-only" src={src} alt={alt} style={style} loading={loading} /><img
	class="dark-only"
	src={darkSrc}
	alt={alt}
	style={style}
	loading={loading}
/>
