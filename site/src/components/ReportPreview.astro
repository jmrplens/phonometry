---
/**
 * Accessible inline preview of a normative `.report()` PDF fiche.
 *
 * The fiches are generated by scripts/generate_reports.py, which writes a
 * `<name>.pdf` and rasterizes its first page to a committed `<name>.png`
 * preview (both under .github/reports, served from raw.githubusercontent).
 * This component embeds that PNG as a clickable thumbnail that opens the PDF.
 * The link's accessible name comes from the image `alt` (the report kind, which
 * names the link's purpose), so a link-only-image is never left unlabelled
 * (WCAG2AA H30); a hidden long description (aria-describedby) supplements it
 * with what the fiche shows, and a separate visible localized download link is
 * always offered. An optional caption sits below.
 *
 * The fiche is an opaque white A4 page, so — unlike the theme-aware figures —
 * a single PNG serves both themes; a light frame keeps it legible on the dark
 * ground. The PNG is NOT byte-checked in CI (its embedded vector plot differs
 * by ~1 ULP across CPUs); the maintainer regenerates it with `make reports`.
 */
interface Props {
	/** Fiche basename in .github/reports, e.g. "iso717_airborne_example". */
	name: string;
	/** Short accessible name for the linked preview (the report kind). */
	title: string;
	/** Textual alternative: what the fiche shows, for screen readers. */
	description: string;
	/** Intrinsic pixel size of the PNG, to reserve layout space (A4 ~1000x1415). */
	width?: number;
	/** Intrinsic pixel size of the PNG, to reserve layout space. */
	height?: number;
	/** Authored display width, e.g. "70%". Full column on phones. */
	displayWidth?: string;
	/** Optional visible caption below the preview. */
	caption?: string;
	/**
	 * Override for the generated element id (aria-describedby target). Only
	 * needed when the same fiche is embedded more than once on a page.
	 */
	id?: string;
}

const REPORTS =
	'https://raw.githubusercontent.com/jmrplens/phonometry/main/.github/reports';

const {
	name,
	title,
	description,
	width = 1000,
	height = 1415,
	displayWidth = '70%',
	caption,
	id,
} = Astro.props;

if (!title?.trim()) {
	throw new Error(`ReportPreview requires a non-empty title (name: ${name})`);
}
if (!description?.trim()) {
	throw new Error(`ReportPreview requires a non-empty description (name: ${name})`);
}

const t = Astro.locals.t;
const pdf = `${REPORTS}/${name}.pdf`;
const png = `${REPORTS}/${name}.png`;
const descId = `${(id ?? name).replaceAll('_', '-')}-desc`;
---

<figure class="report-figure">
	<a
		class="report-link"
		href={pdf}
		aria-describedby={descId}
		rel="noopener"
		style={`width:${displayWidth}`}
	>
		<img src={png} alt={title} width={width} height={height} loading="lazy" />
	</a>
	<p class="sr-only" id={descId}>{description}</p>
	<p class="report-download">
		<a href={pdf} download rel="noopener">{t('phonometry.report.download')}</a>
	</p>
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	.report-figure {
		margin-inline: 0;
		text-align: center;
	}
	/* The white A4 fiche gets a light frame so it reads on the dark theme, a
	   subtle shadow to lift it off the page, and rounded corners. The link is
	   the sizing element (inline width tier); the image fills it. */
	.report-link {
		display: inline-block;
		max-width: 100%;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		background: #fff;
		padding: 0.5rem;
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
		line-height: 0;
	}
	.report-link:hover {
		border-color: var(--sl-color-accent);
	}
	.report-link:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}
	.report-link img {
		width: 100%;
		height: auto;
		border-radius: 0.25rem;
	}
	.report-download {
		font-size: var(--sl-text-sm);
		margin-top: 0.5rem !important;
	}
	figcaption {
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-2);
		margin-top: 0.5rem;
	}
	/* Starlight has no global visually-hidden utility outside its own
	   components, so the description carries its own (matches Video.astro). */
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		margin: -1px;
		padding: 0;
		overflow: hidden;
		clip-path: inset(50%);
		white-space: nowrap;
		border: 0;
	}
</style>
